# ═══════════════════════════════════════════════════════════════════════════
# Wigent — Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════
# Copy this file to `.env` and fill in your values:
#
#   cp .env.example .env
#
# ⚠️  NEVER commit the actual `.env` file to version control.
#     It is already in `.gitignore`.
# ═══════════════════════════════════════════════════════════════════════════

# ── LLM Provider Selection ────────────────────────────────────────────────
# Which provider to use by default.
# Options: openai, anthropic, gemini, groq, ollama, mistral, cohere, litellm
DEFAULT_PROVIDER=openai

# Which agent mode to use by default.
# Options: orchestrator, architect, coder, debugger, reviewer
DEFAULT_MODE=orchestrator

# Override the default model for the selected provider (leave empty for default).
# Examples: gpt-4o, claude-sonnet-4-20250514, gemini-2.5-pro-exp-03-25
LLM_MODEL=

# ── API Keys ──────────────────────────────────────────────────────────────
# 🔴  WARNING: Keep these secret. Never commit them.
#     Obtain keys from:
#       OpenAI:    https://platform.openai.com/api-keys
#       Anthropic: https://console.anthropic.com/settings/keys
#       Google:    https://aistudio.google.com/app/apikey
#       Groq:      https://console.groq.com/keys
#       Mistral:   https://console.mistral.ai/api-keys/
#       Cohere:    https://dashboard.cohere.com/api-keys
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=
COHERE_API_KEY=

# ── Local Provider URLs ──────────────────────────────────────────────────
# Only needed when DEFAULT_PROVIDER is set to ollama or litellm.
OLLAMA_BASE_URL=http://localhost:11434
LITELLM_BASE_URL=http://localhost:4000

# ── Generation Parameters ────────────────────────────────────────────────
# Maximum tokens in each LLM response (1–131072).
MAX_TOKENS=4096

# LLM temperature: 0.0 = deterministic, 1.0 = balanced, 2.0 = very creative.
TEMPERATURE=0.7

# Maximum agent loop iterations before forced stop (1–500).
MAX_ITERATIONS=50

# ── Token / Context Budget ────────────────────────────────────────────────
# Soft limit for the total conversation context window.
# Messages will be trimmed when this is exceeded.
MAX_CONTEXT_TOKENS=128000

# ── Behaviour Flags ───────────────────────────────────────────────────────
# Automatically approve all tool calls without prompting.
# ⚠️  Only set to true in trusted environments.
AUTO_APPROVE=false

# Show diffs before applying file changes.
SHOW_DIFFS=true

# Restrict file operations to the workspace directory.
SANDBOX_MODE=true

# Enable vector memory for cross-session context (experimental).
ENABLE_VECTOR_MEMORY=false

# ── Paths ─────────────────────────────────────────────────────────────────
# Sandbox directory for all file operations (default: ./agent_workspace).
WORKSPACE_DIR=

# Directory for session logs and checkpoints (default: ./.agent/sessions).
SESSION_DIR=

# ── Logging ───────────────────────────────────────────────────────────────
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
